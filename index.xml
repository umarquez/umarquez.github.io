&lt;ul&gt;
&lt;li&gt;&lt;a href=&#34;https://medium.com/@umarquez_mx/23-100-100daysofc0d3-50480b7112d4&#34; rel=&#34;nofollow noreferrer&#34; target=&#34;_blank&#34;&gt;[&lt;sup&gt;23&lt;/sup&gt;&amp;frasl;&lt;sub&gt;100&lt;/sub&gt;] — Compresión LZ77 | LZ77 Compression Algorithm&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;h3 id=&#34;estructuras-de-datos&#34;&gt;Estructuras de datos&lt;/h3&gt;

&lt;ul&gt;
&lt;li&gt;&lt;a href=&#34;https://medium.com/@umarquez_mx/7-100-100daysofc0d3-6eed6b4ceded&#34; rel=&#34;nofollow noreferrer&#34; target=&#34;_blank&#34;&gt;[&lt;sup&gt;7&lt;/sup&gt;&amp;frasl;&lt;sub&gt;100&lt;/sub&gt;] — Tabla de Hash | Hash Table&lt;/a&gt;&lt;/li&gt;
